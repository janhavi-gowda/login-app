pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
                bat 'npx cypress install'
            }
        }


        stage('Build Docker Image') {
            steps {
                bat 'docker build -t login-app .'
            }
        }


        stage('Deploy Container') {
            steps {
                bat 'docker stop login-container || exit 0'
                bat 'docker rm login-container || exit 0'
                bat 'docker run -d --name login-container -p 8081:80 login-app'
            }
        }


        stage('Run Cypress Tests') {
            steps {
                bat 'npx cypress run'
            }
        }


        stage('SonarQube Analysis') {
            steps {
                script {

                    def scannerHome = tool 'SonarScanner'

                    withSonarQubeEnv('SonarQube') {

                        bat """
                        ${scannerHome}\\bin\\sonar-scanner.bat ^
                        -Dsonar.projectKey=login-app ^
                        -Dsonar.sources=. ^
                        -Dsonar.host.url=http://localhost:9002
                        """
                    }
                }
            }
        }
        
        }
    }
}